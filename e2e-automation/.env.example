# Copia este archivo como .env y rellena los valores reales
# NUNCA subas el archivo .env al repositorio

# URL base del sitio a automatizar
BASE_URL=http://172.21.170.81/home

# Credenciales de acceso
APP_USERNAME=your_username_here
APP_PASSWORD=your_password_here

# Opciones del navegador (True = visible para el usuario, False = headless/sin ventana)
HEADLESS=False

# Tiempo máximo de espera por elemento (en milisegundos)
TIMEOUT_MS=15000

# Carpeta donde guardar capturas de pantalla (relativa al script)
SCREENSHOTS_DIR=screenshots
