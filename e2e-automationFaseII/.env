# Copia este archivo como .env y rellena los valores reales
# NUNCA subas el archivo .env al repositorio

# ---------------------------------------------------------------------------
# Conexión al sitio
# ---------------------------------------------------------------------------

# URL base del sitio a automatizar
BASE_URL=http://172.21.170.81/home

# Credenciales de acceso
APP_USERNAME=bci002
APP_PASSWORD=002bci

# ---------------------------------------------------------------------------
# Opciones del navegador
# ---------------------------------------------------------------------------

# True = headless (sin ventana); False = visible para el usuario
HEADLESS=False

# Timeout por defecto para esperar elementos (ms)
TIMEOUT_MS=15000

# Carpeta donde guardar capturas de pantalla (relativa al script)
SCREENSHOTS_DIR=screenshots

# Pausas
PASO2_VISTA_PAUSA_MS=3000
PAUSE_PANTALLA_MS=100

# ---------------------------------------------------------------------------
# Variables nuevas — Ejecución de Casos de Prueba con Datos de Entrada
# ---------------------------------------------------------------------------

# Excel con los casos de prueba (relativo al script o ruta absoluta)
EXCEL_CASOS=casos_prueba.xlsx

# "Si" para mostrar la ventana con botón "Avanzar" entre cada caso.
# Cualquier otro valor (No, vacío, etc.) desactiva la ventana.
ACTIVA_VENTANA=Si

# Tiempo (en segundos) que la ventana "Avanzar" espera antes de auto-cerrarse
VENTANA_TIMEOUT_SEG=20
